{
  "cli": {
    "version": ">= 16.16.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "env:ASC_APP_ID",
        "appleApiKeyId": "env:ASC_API_KEY_ID",
        "appleApiKeyIssuerId": "env:ASC_API_KEY_ISSUER_ID"
      }
    }
  }
}
